# Скопіюйте цей файл у .env та впишіть свої значення.
# (Або задайте ці змінні в налаштуваннях хмари Railway/Render.)

# Токен бота від @BotFather
BOT_TOKEN=123456789:AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA

# Кому надсилати анкети — chat_id отримувача(-ів) через кому.
# Дізнатися chat_id: людина пише боту /whoami (або див. get_chat_id.py).
ADMIN_CHAT_IDS=000000000

# Через скільки ДНІВ після анкети надіслати клієнту запит відгуку
FEEDBACK_DAYS=10

# Через скільки ХВИЛИН нагадати клієнту про незавершену анкету
REMIND_MINUTES=60

# БЕЗКОШТОВНИЙ ключ Google Gemini для AI-аналізу: https://aistudio.google.com/apikey
GEMINI_API_KEY=

# (необов'язково) платний Claude як запасний варіант
ANTHROPIC_API_KEY=
